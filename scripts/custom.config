manifest {
	description = 'Calculation of custom parameters'
	author = 'Vishram L. Terse'
	nextflowVersion = '20.10.0'
}

params {
	bedtools = "/usr/bin/bedtools"
	samtools = "/home/programs/samtools-1.7/samtools"
	merge_csvs_script = "/home/diagnostics/pipelines/nf-core/rnafusion-3.0.1/scripts/merge-csv_v3.py"
	sed_sh = "/home/diagnostics/pipelines/nf-core/rnafusion-3.0.1/scripts/sed.sh"
	genome = "/home/diagnostics/pipelines/nf-core/rnafusion-3.0.1/references/ensembl/Homo_sapiens.GRCh38.102.all.fa"
	genome_dict = "/home/diagnostics/pipelines/nf-core/rnafusion-3.0.1/references/ensembl/Homo_sapiens.GRCh38.102.all.dict"
	dbsnp = "/home/diagnostics/pipelines/nf-core/rnafusion-3.0.1/references/gatk/Homo_sapiens.GRCh38.dbsnp138.vcf.gz"
	dbsnp_index = "/home/diagnostics/pipelines/nf-core/rnafusion-3.0.1/references/gatk/Homo_sapiens.GRCh38.dbsnp138.vcf.gz.tbi"
	haplotypecaller = "haplotypecaller"
	vardict = "vardict"
	annovar_humandb = "/home/programs/annovar_hg38/annovar/humandb"
	gen_ref = "/home/programs/annovar_hg38/annovar/example/gene_fullxref.txt"
	format_haplotypecaller = "/home/diagnostics/pipelines/nf-core/rnafusion-3.0.1/scripts/format_haplotypecaller.py"
	format_vardict = "/home/diagnostics/pipelines/nf-core/rnafusion-3.0.1/scripts/format_vardict.py"
}

def humandb_real = new File(params.annovar_humandb).canonicalPath
def reffile_real = new File(params.gen_ref).canonicalPath

process {
	withLabel:process_single {
		cpus   = { 1                   }
		memory = { 6.GB * task.attempt }
		time   = { 2.h  * task.attempt }
	}
	withLabel:process_low {
		cpus   = { 8     * task.attempt }
		memory = { 12.GB * task.attempt }
		time   = { 4.h   * task.attempt }
	}
	withLabel:process_inter {
		cpus   = { 16     * task.attempt }
		memory = { 32.GB * task.attempt }
		time   = { 10.h   * task.attempt }
	}
	withLabel:process_medium {
		cpus   = { 32     * task.attempt }
		memory = { 48.GB * task.attempt }
		time   = { 16.h   * task.attempt }
	}
	withLabel:process_high {
		cpus   = { 64    * task.attempt }
		memory = { 72.GB * task.attempt }
		time   = { 16.h  * task.attempt }
	}
	withLabel:process_long {
		time   = { 20.h  * task.attempt }
	}
	withLabel:process_high_memory {
		memory = { 200.GB * task.attempt }
	}


	withName: /(ADD_READGROUPS|MARK_DUPLICATES|SPLIT_N_CIGARREADS|BQSR|APPLY_BQSR|HAPLOTYPECALLER)/ {
		container = 'quay.io/biocontainers/gatk4:4.3.0.0--py36hdfd78af_0'
	}
	withName:ANNOVAR {
		container = 'docker.io/bioinfochrustrasbourg/annovar:2018Apr16'
		containerOptions = "-v ${humandb_real}:/databases/humandb -v ${reffile_real}:/databases/gene_fullxref.txt"
	}
}

profiles {
	docker {
		docker.enabled          = true
		docker.runOptions       = '-u $(id -u):$(id -g)'
	}
}


def trace_timestamp = new java.util.Date().format( 'yyyy-MM-dd_HH-mm-ss')
timeline {
	enabled = true
	file    = "${PWD}/Final_Output//execution_timeline_custom_${trace_timestamp}.html"
}
report {
	enabled = true
	file    = "${PWD}/Final_Output//execution_report_custom_${trace_timestamp}.html"
	overwrite = true
}
trace {
	enabled = true
	file    = "${PWD}/Final_Output//execution_trace_custom_${trace_timestamp}.txt"
}
dag {
	enabled = true
	file    = "${PWD}/Final_Output//pipeline_dag_custom_${trace_timestamp}.html"
}

